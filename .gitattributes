# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Large model files and datasets
*.bin binary
*.onnx binary
*.h5 binary
*.pkl binary
*.pickle binary

# Audio files
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary

# Video files
*.mp4 binary
*.avi binary
*.mov binary
*.wmv binary

# Ensure Docker files use LF
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Configuration files
.env* text eol=lf
*.config.js text eol=lf
*.config.ts text eol=lf
*.config.json text eol=lf

# Package lock files (keep as-is to avoid merge conflicts)
package-lock.json text eol=crlf
yarn.lock text eol=crlf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf

# CI/CD files
.github/workflows/*.yml text eol=lf
.github/workflows/*.yaml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf