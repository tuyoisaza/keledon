{
  "manifest_version": 3,
  "name": "KELEDON Browser Agent",
  "version": "0.1.0",
  "description": "Executes deterministic UI flows for KELEDON. Cloud decides; Agent executes.",

  "action": {
    "default_title": "KELEDON",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://*.mypurecloud.com/*",
    "https://*.genesyscloud.com/*",
    "https://*.genesyscloud.com.au/*",
    "https://*.salesforce.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://*.mypurecloud.com/*",
        "https://*.genesyscloud.com/*",
        "https://*.genesyscloud.com.au/*",
        "https://*.salesforce.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
