{
  "name": "keledon",
  "version": "1.0.0",
  "description": "KELEDON Autonomous Agent System",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm run validate:environment && npm run validate:qdrant && npm run validate:supabase && concurrently \"npm run dev:cloud\" \"npm run dev:landing\"",
    "dev:cloud": "cd cloud && npm install && npm run start:dev",
    "dev:landing": "cd landing && npm install && npm run dev",
    "build": "npm run build:cloud && npm run build:landing",
    "build:cloud": "cd cloud && npm run build",
    "build:landing": "cd landing && npm run build",
    "test": "echo 'Tests not configured for root'",
    "start": "npm run dev",
    "validate:environment": "node scripts/validate-environment.js",
    "validate:qdrant": "node scripts/validate-qdrant.js",
    "validate:supabase": "node scripts/validate-supabase.js"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "express": "^5.2.1",
    "keledon": "file:",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },

  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tuyoisaza/keledon.git"
  },
  "author": "KELEDON Team",
  "keywords": [
    "autonomous-agents",
    "runtime-system"
  ]
}
