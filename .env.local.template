# KELEDON Vector Store - Local Development Environment
# Copy this file to .env.local and update the values

# Vector Store Environment
VITE_VECTOR_STORE_ENV=local

# Qdrant Configuration (Local Docker)
VITE_QDRANT_URL=http://localhost:6333
VITE_QDRANT_API_KEY=

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Backup Configuration
VITE_BACKUP_LOCAL_PATH=./vs-backups
VITE_BACKUP_CLOUD_PATH=

# Development Settings
VITE_DEV_TOOLS=true
VITE_LOG_LEVEL=debug