# KELEDON Environment Configuration
# Copy this file to .env and update values for managed runtime

# Environment Tier
KELEDON_ENV_TIER=PRODUCTION_MANAGED

# Backend Configuration
KELEDON_CLOUD_BASE_URL=https://api.keledon.example

# API Endpoints
RAG_RETRIEVE_ENDPOINT=/rag/retrieve
RAG_EVALUATE_ENDPOINT=/rag/evaluate
LISTENING_SESSIONS_ENDPOINT=/listening-sessions
INTERFACES_ENDPOINT=/api/interfaces

# WebSocket Configuration
LISTEN_WS_ENDPOINT=/listen/ws

# Development Settings
DEBUG=false
LOG_LEVEL=info
