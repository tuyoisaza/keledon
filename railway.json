{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "cloud/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node -e \"console.log('START'); const fs=require('fs'); console.log('dist exists:', fs.existsSync('dist/main.js')); console.log('files:', fs.readdirSync('.'))\"",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "environment": [
      {
        "key": "NODE_ENV",
        "value": "development"
      },
      {
        "key": "PORT",
        "value": "3000"
      }
    ]
  }
}
