# KELEDON Environment Configuration Template
# Copy to .env.local or .env.production and fill in real values

# === CORE ENVIRONMENT ===
# REQUIRED: Must be 'local' or 'production'
NODE_ENV=local

# === PHASE 0 - BOOTABLE ===
CLOUD_PORT=3001
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# === PHASE 1 - VECTOR-READY ===
# Local: http://localhost:6333
# Production: https://your-qdrant-domain.com
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # OPTIONAL for local, REQUIRED for production

# === PHASE 2 - DATABASE-READY ===
# Local: http://localhost:54321 (Supabase Docker/CLI)
# Production: https://your-project.supabase.co
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-local-or-production-key

# === STT/TTS PROVIDERS ===
DEFAULT_STT_PROVIDER=whisper
DEFAULT_TTS_PROVIDER=coqui-xtts-v2

# Local development endpoints
WHISPER_API_URL=http://localhost:8000/stt/whisper
WHISPERX_API_URL=http://localhost:8000/stt/whisperx
COQUI_TTS_URL=http://localhost:8000/tts/coqui
QWEN3_TTS_URL=http://localhost:8000/tts/qwen3
RPA_LOCAL_URL=http://localhost:8000/rpa

# API Keys (set as needed)
WHISPER_API_KEY=
WHISPERX_API_KEY=
COQUI_TTS_KEY=
COQUI_TTS_VOICE=
COQUI_TTS_LANGUAGE=en
QWEN3_TTS_KEY=
QWEN3_TTS_VOICE=
QWEN3_TTS_VOICE_DESCRIPTION=
QWEN3_TTS_LANGUAGE=en
QWEN3_TTS_SPEED=1.0