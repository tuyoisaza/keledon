{
  "name": "cloud",
  "version": "0.0.97",
  "description": "KELEDON Backend",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node scripts/c13-regression-sentinel.js && npx tsc -p tsconfig.mvp.json",
    "start": "node dist/main",
    "start:dev": "node canonical-dev-server.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "build:typescript": "npx tsc --noEmit",
    "dev:vector-store": "npm run start:dev",
    "build:vector-store": "npm run build && npm run package:vector-store",
    "package:vector-store": "echo 'Vector Store backend built successfully'",
    "dev:full": "concurrently \"npm run dev:vector-store\" \"cd ../landing && npm run dev\"",
    "prepare:env": "echo 'Environment preparation complete'",
    "seed": "npx ts-node scripts/seed-main-data.ts",
    "db:push": "npx prisma db push",
    "proof:c07:local": "node scripts/c07-local-proof.js --dev-only-bootstrap",
    "proof:c09:local": "node scripts/c09-local-proof.js --dev-only-bootstrap",
    "proof:c10:local": "node scripts/c10-local-proof.js --dev-only-bootstrap",
    "proof:c12:local": "node scripts/c12-local-proof.js --dev-only-bootstrap",
    "proof:c12:ci": "node scripts/c13-ci-guardrail.js --dev-only-bootstrap",
    "guard:regression": "node scripts/c13-regression-sentinel.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed:qdrant": "npx ts-node scripts/seed-qdrant.ts"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/testing": "^11.1.12",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@qdrant/qdrant-js": "^1.17.0",
    "@types/bcrypt": "^5.0.2",
    "@types/os-utils": "^0.0.4",
    "@types/uuid": "^9.0.0",
    "bcrypt": "^5.1.1",
    "elevenlabs": "^1.59.0",
    "google-auth-library": "^9.15.1",
    "openai": "^6.22.0",
    "pg": "^8.18.0",
    "playwright": "^1.58.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/websockets": "^11.1.12",
    "@prisma/client": "^5.22.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.7",
    "concurrently": "^8.2.2",
    "jest": "^30.3.0",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3"
  }
}
