# Local development / proof-only configuration.
# Never use these localhost values in PRODUCTION_MANAGED.

KELEDON_ENV_TIER=DEV_LOCAL
NODE_ENV=development

KELEDON_CLOUD_BASE_URL=http://localhost:3001
KELEDON_QDRANT_URL=http://localhost:6333
KELEDON_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

KELEDON_QDRANT_API_KEY=
KELEDON_QDRANT_COLLECTION=keledon

# Preferred local contract
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?schema=public

# Legacy fallback (only if DATABASE_URL is not provided)
SUPABASE_HOST=localhost
SUPABASE_PORT=54322
SUPABASE_USER=postgres
SUPABASE_PASSWORD=postgres
SUPABASE_DB=postgres
