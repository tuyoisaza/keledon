# C:\KELEDON\cloud\.env.example
# Template for managed production runtime.
# Local Docker values belong only in .env.local* files.

KELEDON_ENV_TIER=PRODUCTION_MANAGED
NODE_ENV=production

# Canonical service endpoints
KELEDON_CLOUD_BASE_URL=https://api.keledon.example
KELEDON_SUPABASE_URL=https://project-ref.supabase.co
KELEDON_QDRANT_URL=https://qdrant.keledon.example
KELEDON_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://otel.keledon.example/v1/traces

# Canonical credentials
KELEDON_SUPABASE_ANON_KEY=REDACTED
QDRANT_API_KEY=REDACTED

# Managed database connection settings
SUPABASE_HOST=managed-supabase-postgres-host
SUPABASE_PORT=5432
SUPABASE_USER=postgres
SUPABASE_PASSWORD=REDACTED
SUPABASE_DB=postgres

CORS_ORIGINS=https://keledon.tuyoisaza.com,chrome-extension://*
DEFAULT_STT_PROVIDER=whisper
DEFAULT_TTS_PROVIDER=coqui-xtts-v2
WHISPER_API_URL=https://keledon.tuyoisaza.com/stt/whisper
WHISPER_API_KEY=REDACTED
WHISPERX_API_URL=https://keledon.tuyoisaza.com/stt/whisperx
WHISPERX_API_KEY=REDACTED
COQUI_TTS_URL=https://keledon.tuyoisaza.com/tts/coqui
COQUI_TTS_KEY=REDACTED
COQUI_TTS_VOICE=REDACTED
COQUI_TTS_LANGUAGE=en
QWEN3_TTS_URL=https://keledon.tuyoisaza.com/tts/qwen3
QWEN3_TTS_KEY=REDACTED
QWEN3_TTS_VOICE=REDACTED
QWEN3_TTS_VOICE_DESCRIPTION=REDACTED
QWEN3_TTS_LANGUAGE=en
QWEN3_TTS_SPEED=1.0
RPA_LOCAL_URL=https://keledon.tuyoisaza.com/rpa
