{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmitOnError": false
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/app.controller.ts",
    "src/app.service.ts",
    "src/services/session.service.ts",
    "src/services/database-health.service.ts",
    "src/services/database-persistence.service.ts",
    "src/services/decision-engine.service.ts",
    "src/services/tts.service.ts",
    "src/services/ai-loop.service.ts",
    "src/services/agent-monitoring.service.ts",
    "src/health/**/*",
    "src/dto/**/*",
    "src/prisma/**/*",
    "src/telemetry/**/*",
    "src/gateways/agent.gateway.ts",
    "src/controllers/team.controller.ts",
    "src/controllers/mvp-data.controller.ts",
    "src/config/**/*",
    "src/listening-sessions/**/*",
    "src/rag/**/*",
    "src/mvp/**/*",
    "src/auth-local/**/*",
    "src/crud/**/*"
  ],
  "exclude": [
    "src/controllers/analytics.controller.ts",
    "src/controllers/dashboard.controller.ts",
    "src/controllers/rbac-analysis.controller.ts",
    "src/gateways/dashboard.gateway.ts",
    "src/modules/**/*",
    "src/local-services/**/*",
    "src/services/ui-automation.service.ts",
    "src/services/flow-execution.service.ts",
    "src/services/security.service.ts",
    "src/services/integration-health.service.ts",
    "src/services/real-time-alerting.service.ts",
    "src/services/system-monitoring.service.ts",
    "src/services/rbac-recommendation.service.ts",
    "src/services/voice-analytics.service.ts",
    "src/rbac/**/*"
  ]
}
