{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmitOnError": false
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/app.controller.ts",
    "src/app.service.ts",
    "src/entities/**/*",
    "src/services/session.service.ts",
    "src/services/database-health.service.ts",
    "src/health/**/*",
    "src/dto/**/*",
    "src/prisma/**/*",
    "src/telemetry/**/*",
    "src/gateways/agent.gateway.ts",
    "src/controllers/team.controller.ts",
    "src/config/runtime-tier.ts"
  ]
}