# KELEDON Vector Store - Production Environment
# Deploy this to production servers with appropriate values

# Vector Store Environment
VITE_VECTOR_STORE_ENV=production

# Qdrant Configuration (Production)
VITE_QDRANT_URL=https://keledon.tuyoisaza.com/qdrant
VITE_QDRANT_API_KEY=your_production_qdrant_api_key

# OpenAI Configuration
VITE_OPENAI_API_KEY=your_production_openai_api_key

# Backup Configuration
VITE_BACKUP_LOCAL_PATH=./vs-backups
VITE_BACKUP_CLOUD_PATH=s3://keledo-backups/vector-store

# Production Settings
VITE_DEV_TOOLS=false
VITE_LOG_LEVEL=error