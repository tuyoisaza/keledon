# === PHASE 1 - VECTOR-READY ===
QDRANT_URL=https://your-production-qdrant.com
QDRANT_API_KEY=your-production-qdrant-key

# === PHASE 2 - DATABASE-READY ===
SUPABASE_URL=https://isoyzcvjoevyphnaznkl.supabase.co
SUPABASE_KEY=sb_publishable_9sKVxamNyK4CdXM-yH69qg_fEHRvHRa

# === STT/TTS PROVIDERS ===
