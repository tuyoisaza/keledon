# KELEDON Production Environment Variables
# Copy this file to .env and customize for your environment

# Environment
NODE_ENV=production

# Application Configuration
PORT=3001
SINGLE_CONTAINER=true

# Database Configuration
POSTGRES_DB=keledon_prod
POSTGRES_USER=keledon
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# WebSocket Configuration
WEBSOCKET_PORT=3001

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# STT Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here
STT_PROVIDER=deepgram

# TTS Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TTS_PROVIDER=elevenlabs

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Performance
MAX_SESSIONS=1000
SESSION_TIMEOUT=3600000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,png

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=KELEDON <noreply@yourdomain.com>

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/keledon.crt
SSL_KEY_PATH=/etc/ssl/private/keledon.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

# API Keys (External Services)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_CLOUD_KEY=your_google_cloud_key_here

# Development Overrides (set to false in production)
DEBUG=false
ENABLE_PROFILING=false
ENABLE_DEBUG_ENDPOINTS=false

# Feature Flags
ENABLE_WEBRTC=true
ENABLE_RPA=true
ENABLE_AI_DECISIONS=true
ENABLE_SESSION_RECORDING=true

# Resource Limits
MAX_MEMORY_USAGE=2g
MAX_CPU_USAGE=2
MAX_CONCURRENT_AGENTS=10

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3